# =============================================================================
# Splunk-AITK-DSDL — what NOT to commit
# =============================================================================
# Note: .gitignore does NOT support inline comments. Anything after a
# pattern is treated as part of the pattern. Comments live on their own lines.

# -----------------------------------------------------------------------------
# Splunkbase app packages — staged by hand, not redistributable, often >50 MB.
# Keep the folder + its README in git, block the .tgz payloads.
# -----------------------------------------------------------------------------
splunk-apps/**
!splunk-apps/README.md
!splunk-apps/.gitkeep

# Generated by setup.ps1 / setup.sh — contains the password + app paths.
docker/.env

# -----------------------------------------------------------------------------
# BOTSv1 staging — only used if you DON'T reuse the sibling lab's extracted
# data (setup.* prefers ../Splunk-Environment-Lab/bots-data/botsv1/). Either
# way the dataset is huge; keep the folder + .gitkeep, block the payload.
# -----------------------------------------------------------------------------
bots-data/**
!bots-data/README.md
!bots-data/botsv1/
!bots-data/botsv1/.gitkeep

# -----------------------------------------------------------------------------
# Splunk artefacts & app packages
# -----------------------------------------------------------------------------
*.spl
*.tsidx
journal.gz
rawdata/
var/lib/splunk/

# -----------------------------------------------------------------------------
# Generic archives & installers — GitHub-hostile
# -----------------------------------------------------------------------------
*.tgz
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.7z
*.rar
*.iso
*.dmg
*.deb
*.rpm
*.msi
*.exe

# -----------------------------------------------------------------------------
# Secrets & credentials
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.pfx
*.p12
credentials.json
**/passwords.conf
**/server.conf

# -----------------------------------------------------------------------------
# Python (DSDL notebooks / model code you might add)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/
.pytest_cache/

# -----------------------------------------------------------------------------
# OS junk / editor
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.tmp

# -----------------------------------------------------------------------------
# Logs at repo root only
# -----------------------------------------------------------------------------
/*.log
