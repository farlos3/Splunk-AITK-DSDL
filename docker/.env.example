# Copy to docker/.env (or just run setup.ps1 / setup.sh, which generates it).
# docker/.env is gitignored — it holds your admin password + app paths.

# Splunk admin password (min 8 chars; Splunk rejects weak/common ones).
SPLUNK_PASSWORD=p@ssw0rd

# HTTP Event Collector token (used by some DSDL workflows).
SPLUNK_HEC_TOKEN=aitk-hec-token-CHANGE-ME

# Comma-separated CONTAINER-side paths to the staged app .tgz files,
# installed in this order at first boot: PSC -> AITK/MLTK -> DSDL.
# splunk-apps/ is bind-mounted read-only at /tmp/apps inside the container.
# setup.* fills this in automatically from whatever you staged.
SPLUNK_APPS_URL=/tmp/apps/python-for-scientific-computing-for-linux-64-bit_XX.tgz,/tmp/apps/splunk-machine-learning-toolkit_XX.tgz,/tmp/apps/splunk-app-for-data-science-and-deep-learning_XX.tgz

# Image the mltk-dev model/JupyterLab container runs. Default = this lab's
# LOCALLY-BUILT custom image (docker/custom-image/ — the golden base plus your
# extra libs from requirements.extra.txt). setup.sh builds it and writes the tag
# here. To use a plain published image instead, set a golden tag and run
# `./setup.sh --golden-image <tag>` (or --skip-pull so it doesn't rebuild), e.g.
#   GOLDEN_IMAGE=splunk/mltk-container-golden-cpu:5.2.3
# A GPU golden tag works too if you have an NVIDIA GPU + the Container Toolkit.
GOLDEN_IMAGE=splunkaitk/mltk-container-custom:local

# (Optional) golden mltk-dev HOST ports. Defaults are the DSDL dev slot
# 5000/8888/6006. The DSDL LLM-RAG container (LLM Chat, started from
# Container Management) wants those SAME host ports, so golden and LLM-RAG
# can't both use them. Uncomment to move golden off them and run both at once
# (JupyterLab then at https://localhost:8889). Caveat: with these set, DSDL's
# :5000 endpoint points at LLM-RAG, so MLTKContainer fit/apply (DGA POC) won't
# reach golden until you remove them. See docs/GUIDE.md 5.2.
#MLTK_DEV_API_PORT=5001
#MLTK_DEV_JUPYTER_PORT=8889
#MLTK_DEV_TB_PORT=6007
